# Version control
.git
.gitignore

# Frontend build artifacts and dependencies (rebuilt inside Docker)
frontend/node_modules
frontend/dist
frontend/.env*

# Python cache and local DB
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
backend/aiobs.db
backend/.venv
backend/venv

# SDK (not needed in the runtime image)
sdk/

# Dev / editor files
.vscode
.idea
*.swp
*.swo
**/.DS_Store
**/htmlcov
**/.coverage
